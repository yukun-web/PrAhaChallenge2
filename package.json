{
  "name": "praha-challenge",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .local.env -- ts-node-dev --respawn src/main.ts",
    "build": "tsc",
    "start": "node dist/src/main.js",
    "lint": "eslint 'src/**/*.ts'",
    "test": "dotenv -e .test.env -- jest",
    "test:unit": "dotenv -e .test.env -- jest --testPathIgnorePatterns='/e2e/'",
    "test:e2e": "dotenv -e .test.env -- jest --testPathPattern=e2e --runInBand",
    "migrate:dev": "dotenv -e .local.env -- prisma migrate dev",
    "migrate:test": "dotenv -e .test.env -- prisma migrate reset --force",
    "seed": "dotenv -e .local.env -- ts-node prisma/seed.ts",
    "generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "dotenv-cli": "^7.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "prisma": "^5.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
